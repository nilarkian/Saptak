{
  "model": "claude-opus-4-6",
  "env": {
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "400000"
  },
  "permissions": {
    "allow": [
      "Bash(bundle exec jekyll *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(python *.py)",
      "Bash(find . *)",
      "Bash(wc *)",
      "Bash(cat *)",
      "Bash(echo *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "Get-Content .claude/decisions/log.md -TotalCount 30 2>$null; exit 0"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'COMPACT OCCURRED — re-read core.md, workflow.md, and the relevant domain rule before proceeding. Do not assume rules survived compression.'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bundle exec jekyll build 2>&1 | Select-Object -Last 15"
          }
        ]
      }
    ]
  }
}
